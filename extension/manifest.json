{
  "manifest_version": 3,
  "name": "HoodLink",
  "version": "0.2.0",
  "description": "Bridge between HoodLink server and Robinhood Legend",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.robinhood.com/*",
    "http://127.0.0.1:7878/*",
    "http://localhost:7878/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.robinhood.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://127.0.0.1:7878/*", "http://localhost:7878/*"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/inject.js"],
      "matches": ["https://*.robinhood.com/*"]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "HoodLink",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
